@startuml Activity Diagram - Анализ веб-ресурса
skinparam activity {
    BackgroundColor LightBlue
    BorderColor DarkBlue
    FontColor Black
}

skinparam swimlaneBorderColor LightGray

|Пользователь|
start
:Открыть страницу входа;
:Ввести логин и пароль;
:Нажать кнопку "Войти";

if (Данные верны?) then (Да)
    |Система|
    :Проверить учетные данные;
    :Создать сессию пользователя;
    :Перенаправить на дашборд;
    
    |Пользователь|
    :Нажать "Добавить веб-ресурс";
    :Ввести URL и название сайта;
    :Ввести описание (опционально);
    :Выбрать категорию (опционально);
    :Нажать "Сохранить";
    
    |Система|
    :Проверить валидность URL;
    :Проверить дубликаты в БД;
    
    if (URL валиден и не дублируется?) then (Да)
        :Создать запись в таблице websites;
        :Сохранить в базу данных;
        :Отобразить сообщение об успехе;
        
        |Пользователь|
        :Нажать "Запустить анализ";
        
        |Система|
        :Создать запись в таблице analyses;
        :Установить статус "pending";
        
        partition "SEO Анализ" {
            :Загрузить HTML страницу;
            :Извлечь мета-теги;
            :Проанализировать заголовки (H1, H2);
            :Подсчитать внутренние ссылки;
            :Подсчитать внешние ссылки;
            :Проверить изображения на alt-текст;
            :Вычислить SEO score;
        }
        
        partition "Анализ производительности" {
            :Измерить время загрузки;
            :Измерить First Contentful Paint;
            :Измерить Largest Contentful Paint;
            :Вычислить Cumulative Layout Shift;
            :Измерить First Input Delay;
            :Вычислить Time to Interactive;
            :Подсчитать размер страницы;
            :Подсчитать количество запросов;
            :Вычислить Performance score;
        }
        
        partition "Анализ доступности" {
            :Проверить alt-тексты изображений;
            :Проверить ARIA-метки;
            :Проверить контрастность цветов;
            :Проверить навигацию с клавиатуры;
            :Проверить метки форм;
            :Вычислить Accessibility score;
        }
        
        partition "Анализ безопасности" {
            :Проверить наличие HTTPS;
            :Проверить заголовки безопасности;
            :Проверить уязвимые библиотеки;
            :Проверить смешанный контент;
            :Вычислить Security score;
        }
        
        partition "UX Анализ" {
            :Проверить мобильную адаптацию;
            :Проверить адаптивный дизайн;
            :Проверить читаемость шрифтов;
            :Проверить навигацию;
            :Вычислить UX score;
        }
        
        :Сохранить SEO метрики в БД;
        :Сохранить Performance метрики в БД;
        :Сохранить Accessibility метрики в БД;
        :Сохранить Security метрики в БД;
        :Сохранить UX метрики в БД;
        
        :Обновить статус анализа на "completed";
        :Вычислить общий score;
        
        |Пользователь|
        :Просмотреть результаты анализа;
        
        if (Хотите сгенерировать отчет?) then (Да)
            :Выбрать формат отчета;
            
            |Система|
            if (Формат == HTML?) then (Да)
                :Сгенерировать HTML отчет;
            elseif (Формат == PDF?) then (Да)
                :Сгенерировать PDF отчет;
            elseif (Формат == JSON?) then (Да)
                :Сгенерировать JSON отчет;
            elseif (Формат == DOCX?) then (Да)
                :Сгенерировать DOCX отчет;
            elseif (Формат == XLSX?) then (Да)
                :Сгенерировать XLSX отчет;
            endif
            
            :Сохранить путь к файлу в БД;
            
            |Пользователь|
            :Скачать отчет;
        endif
        
        if (Хотите сравнить с другими сайтами?) then (Да)
            :Выбрать другие сайты для сравнения;
            
            |Система|
            :Получить последние анализы выбранных сайтов;
            :Сравнить метрики между сайтами;
            :Сгенерировать таблицу сравнения;
            
            |Пользователь|
            :Просмотреть результаты сравнения;
        endif
        
        stop
    else (Нет)
        |Система|
        :Отобразить ошибку валидации;
        
        |Пользователь|
        :Исправить данные;
        :Повторить ввод;
    endif
else (Нет)
    |Система|
    :Отобразить ошибку аутентификации;
    
    |Пользователь|
    :Повторить ввод логина и пароля;
endif

@enduml
